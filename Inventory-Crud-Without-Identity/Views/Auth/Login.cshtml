@model Inventory_Crud.Models.DTOs.Auth.LoginDto
@{
    ViewData["Title"] = "Login";
   
}

<h1>Login</h1>

<div class="row">
    <div class="col-md-4">
        <section>
            <form id="account" method="post">

                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" type="password"/>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
                </div>
                <div>
                   
                    <p>
                        <a asp-action="Register" >Register as a new user</a>
                    </p>

                </div>
            </form>
        </section>
    </div>
</div>
<partial name="_ValidationScriptsPartial" />